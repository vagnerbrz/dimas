# Configuração do Micro Serviço de Impressão
# Copie este arquivo para .env e configure os valores

# Token de autenticação (deve ser o mesmo no Laravel hospedado)
LOCAL_PRINT_API_TOKEN=seu_token_super_secreto_aqui

# Configurações padrão de impressão
DEFAULT_PRINT_CONNECTION=network
DEFAULT_PRINT_HOST=192.168.0.100
DEFAULT_PRINT_PORT=9100
# DEFAULT_PRINT_FILE_PATH=/tmp/receipt.txt

# Porta do servidor HTTP
PORT=3000
